{
  "version": 2,
  "functions": {
    "server/index.ts": {
      "runtime": "nodejs20.x",
      "includeFiles": "dist/public/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/server/index.ts"
    }
  ]
}
